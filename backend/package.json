{
  "name": "sistema-marcacao-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"const fs=require('fs'); let s=fs.readFileSync('prisma/schema.prisma','utf8'); s=s.replace('provider = \\\"sqlite\\\"', 'provider = \\\"postgresql\\\"'); fs.writeFileSync('prisma/schema.prisma', s);\" && prisma generate && tsc",
    "start": "prisma db push && node dist/server.js",
    "seed": "tsx prisma/seed.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@fastify/jwt": "^7.2.0",
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.25.0",
    "mercadopago": "^3.1.0",
    "nodemailer": "^9.0.3",
    "pino-pretty": "^13.1.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}
