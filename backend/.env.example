# Configuração do Banco de Dados PostgreSQL (Railway ou Supabase)
DATABASE_URL="postgresql://usuario:senha@host:5432/nomedobanco?schema=public"

# Configuração do Servidor
PORT=3001
CORS_ORIGIN="http://localhost:5173,https://seusite.com.br"
JWT_SECRET="gere_uma_chave_secreta_longa_e_segura_aqui"

# Integração Mercado Pago
MERCADOPAGO_ACCESS_TOKEN="TEST-1234567890-abcdef-12345"
MERCADOPAGO_WEBHOOK_SECRET="v1_xyz" # Opcional, usado para validar a assinatura do webhook

# Integração WhatsApp Cloud API (Opcional)
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_ID=""

# Configuração de E-mail (SMTP - Opcional, para envio de recuperação de senha)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BoraMarka <noreply@boramarka.com.br>"

